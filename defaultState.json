            ]
        }
    ],
    "fetchModules": [
        {
            "slug": "hostName",
            "data": {}
        },
        {
            "slug": "header",
            "data": { "textContent": "----------------" }
        },
        {
            "slug": "header",
            "data": { "textContent": "Image" }
        },
        {
            "slug": "image",
            "data": {
                "keyConfig": {
                    "category": "image",
                    "emoji": ""
                }
            }
        },
        {
            "slug": "header",
            "data": { "textContent": "Platform" }
        },
        {
            "slug": "os",
            "data": {
                "keyConfig": {
                    "category": "Platform",
                    "emoji": "",
                    "textContent": "OS"
                }
            }
        },
        {
            "slug": "locale",
            "data": {
                "keyConfig": {
                    "category": "Platform",
                    "emoji": "",
                    "textContent": "locale"
                }
            }
        },
        {
            "slug": "header",
            "data": { "textContent": "Time" }
        },
        {
            "slug": "time",
            "data": {
                "keyConfig": { "category": "Time", "emoji": "󰊷" },
                "timezones": [
                    {
                        "airport": "SLC",
                        "timeZone": "America/Denver",
                        "hour12": false,
                        "hour": "2-digit",
                        "minute": "2-digit"
                    },
                    {
                        "airport": "NYC",
                        "timeZone": "America/New_York",
                        "hour12": false,
                        "hour": "2-digit",
                        "minute": "2-digit"
                    },
                    {
                        "airport": "BER",
                        "timeZone": "Europe/Berlin",
                        "hour12": false,
                        "hour": "2-digit",
                        "minute": "2-digit"
                    }
                ]
            }
        },
        {
            "slug": "header",
            "data": { "textContent": "Connected from" }
        },
        {
            "slug": "ip",
            "data": {
                "keyConfig": {
                    "category": "Connection",
                    "emoji": "󰌘",
                    "textContent": "IPv4"
                }
            }
        },
        {
            "slug": "location",
            "data": {
                "keyConfig": {
                    "category": "Connection",
                    "emoji": "",
                    "textContent": "Location"
                }
            }
        },
        {
            "slug": "weather",
            "data": {
                "keyConfig": {
                    "category": "Weather",
                    "emoji": "󰃶",
                    "dateFormat": [
                        "en-GB",
                        {
                            "weekday": "short",
                            "month": "2-digit",
                            "day": "2-digit"
                        }
                    ]
                },
                "latitude": null,
                "longitude": null,
                "label": null
            }
        }
    ]
}
